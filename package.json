{
  "name": "react-project-imli",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "generate-types": "graphql-codegen --config src/codegen.ts",
    "dev:server": "nodemon -L --watch server --ext js --exec \"node server/index.js\"",
    "start": "yarn generate-types && yarn dev:server",
    "build": "vite build",
    "preview": "vite preview",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.js",
    "setup:sdks": "yarn dlx @yarnpkg/sdks vscode"
  },
  "dependencies": {
    "@apollo/client": "3.7.11",
    "@dnd-kit/core": "6.1.0",
    "@dnd-kit/modifiers": "7.0.0",
    "@dnd-kit/sortable": "8.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@tinymce/tinymce-react": "5.0.1",
    "autoprefixer": "10.4.14",
    "classnames": "2.3.2",
    "dnd-kit": "0.0.2",
    "dotenv": "16.0.3",
    "export-to-csv": "1.4.0",
    "express": "^5.2.1",
    "graphql": "16.6.0",
    "nodemon": "^3.1.14",
    "normalize.css": "8.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-helmet-async": "2.0.5",
    "react-router-dom": "6.10.0",
    "reset-css": "5.0.1",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-codegen/typescript": "4.1.2",
    "@graphql-codegen/typescript-operations": "4.1.2",
    "@types/eslint": "8.37.0",
    "@types/express": "^5",
    "@types/react": "19.0.5",
    "@types/react-csv": "1.1.10",
    "@types/react-dom": "19.0.3",
    "@types/react-helmet": "6.1.6",
    "@types/react-router-dom": "5.3.3",
    "@typescript-eslint/eslint-plugin": "5.59.2",
    "@typescript-eslint/parser": "5.59.2",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "8.36.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-react": "7.32.2",
    "get-graphql-schema": "2.1.2",
    "prettier": "3.0.2",
    "sass-embedded": "^1.98.0",
    "typescript": "4.9.5",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
